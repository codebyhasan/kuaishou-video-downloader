{
  "manifest_version": 3,
  "name": "Kuaishou Video Downloader",
  "version": "1.0.0",
  "description": "Extract and download videos from Kuaishou (快手)",
  "browser_specific_settings": {
    "gecko": {
      "id": "kuaishou-video-downloader-addon@extension",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.kuaishou.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["clipboardWrite", "clipboardRead", "tabs"],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Kuaishou Downloader"
  }
}
